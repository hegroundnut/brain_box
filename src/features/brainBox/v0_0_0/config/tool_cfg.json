                                    "params": {
                                        "device_id": "目标无人机设备 ID",
                                        "command": "指令内容字典，如 {'type': 'takeoff', 'altitude': 50.0} 或 {'type': 'goto', 'latitude': 39.9, 'longitude': 116.4, 'altitude': 100.0}"
                                    }
                                },
                                {
                                    "func_name": "navigation_instruction",
                                    "func_desc": "接收导航指令，调用算法生成轨迹并上报至边缘服务器",
                                    "params": {
                                        "instruction_id": "导航指令唯一 ID",
                                        "device_id": "目标无人机设备 ID",
                                        "target_position": "目标位置字典 {'latitude': ..., 'longitude': ..., 'altitude': ...}",
                                        "algorithm": "可选，导航算法名称，默认 'simple_linear'",
                                        "parameters": "可选，算法参数字典，如 {'step_count': 5, 'speed': 8.0}"
                                    }
                                },
                                {
                                    "func_name": "execute_trajectory",
                                    "func_desc": "执行已生成的导航轨迹，将航点序列发送至无人机",
