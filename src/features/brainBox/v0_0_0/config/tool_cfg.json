                                    "params": {}
                                },
                                {
                                    "func_name": "update_config",
                                    "func_desc": "更新类脑盒子配置信息（支持部分更新）",
                                    "params": {
                                        "box_id": "可选，类脑盒子唯一标识符",
                                        "edge": "可选，边缘服务器配置对象 {base_url, heartbeat_interval, ...}",
                                        "mavlink": "可选，MAVLink通信配置对象 {connection_string, scan_interval, ...}",
                                        "logging": "可选，日志配置对象 {level, log_dir, ...}",
                                        "storage": "可选，存储配置对象 {db_path, device_evict_timeout}"
                                    }
                                },
                                {
                                    "func_name": "scan_drones",
                                    "func_desc": "立即触发网络扫描，发现并注册在线无人机",
                                    "params": {}
                                },
                                {
                                    "func_name": "query_drones",
                                    "func_desc": "查询无人机详细信息",
                                    "params": {
                                        "device_id": "可选，指定无人机 ID 进行精确查询"
                                    }
                                },
                                {
                                    "func_name": "drones_summary",
                                    "func_desc": "获取当前管辖的所有无人机汇总统计信息（总数、在线/离线数及列表）",
                                    "params": {}
                                },
                                {
                                    "func_name": "send_command",
