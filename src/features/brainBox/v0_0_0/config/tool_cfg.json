                "tool_uniq_id": "2054136993080795138",
                "tool_desc": "类脑盒子（BrainBox）：边缘计算节点，负责无人机接入、协议转换、局部导航算法执行及状态上报。",
                "tool_cfg": [
                    {
                        "FunDesc": "类脑盒子核心功能：包含配置管理、无人机扫描与查询、控制指令转发、导航指令处理及系统状态查询。",
                        "ReqParam": {
                            "dtype": "brainBox",
                            "version": "0.0.0",
                            "subfuncs": [
                                {
                                    "func_name": "get_config",
