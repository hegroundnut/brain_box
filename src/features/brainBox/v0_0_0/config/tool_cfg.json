                                    "func_desc": "获取类脑盒子系统运行状态、无人机汇总及可用算法/协议",
                                    "params": {}
                                },
                                {
                                    "func_name": "list_protocols",
                                    "func_desc": "获取已注册的通信协议列表",
                                    "params": {}
